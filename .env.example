# Public Healthie links generated in your Healthie account.
# These may be visible in the browser and must never contain API keys.
NEXT_PUBLIC_HEALTHIE_PORTAL_URL=
NEXT_PUBLIC_HEALTHIE_BOOKING_URL=
NEXT_PUBLIC_HEALTHIE_INTAKE_URL=

# Server-only values for a future API integration. Do not prefix these with NEXT_PUBLIC.
HEALTHIE_API_URL=https://api.gethealthie.com/graphql
HEALTHIE_API_KEY=
HEALTHIE_AUTHORIZATION_SHARD=
HEALTHIE_WEBHOOK_SIGNATURE_SECRET=
